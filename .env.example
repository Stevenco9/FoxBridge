REGFOX_API_KEY=your_api_key_here
REGFOX_EVENT_ID=your_test_event_id_here

# Optional local scanner server (disabled by default)
# SCANNER_SERVER_ENABLED=true
# SCANNER_SERVER_PORT=3847

# Optional Supabase cloud sync (disabled when unset)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# SUPABASE_ANON_KEY=your_anon_key
# SUPABASE_CONFERENCE_ID=your_conference_uuid  # optional; auto-created on first publish

# Mobile PWA URL shown to volunteers (hosted production address)
# MOBILE_APP_URL=https://scanner.your-conference.example.com
