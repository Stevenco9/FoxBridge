{
  "name": "foxbridge",
  "version": "0.1.1",
  "description": "Badge printing and attendee management for RegFox events.",
  "author": "AdAgrA Mexico",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE vite",
    "dev:mobile": "npm run dev --prefix apps/mobile",
    "build": "tsc --noEmit && vite build",
    "build:mobile": "npm run build --prefix apps/mobile",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "pack:mac": "npm run build && electron-builder --mac dir",
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "test:regfox": "tsx scripts/test-regfox.ts",
    "test:meal-order": "tsx scripts/test-meal-order.ts",
    "test:payment": "tsx scripts/test-payment.ts",
    "test-payment": "tsx scripts/test-payment.ts",
    "test:printer": "bash scripts/test-printer.sh"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@supabase/supabase-js": "^2.109.0",
    "better-sqlite3": "^12.11.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-qr-code": "^2.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^36.4.0",
    "electron-builder": "^26.15.3",
    "electron-rebuild": "^3.2.9",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vite-plugin-electron": "^0.29.0"
  },
  "build": {
    "appId": "com.foxbridge.desktop",
    "productName": "FoxBridge",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!**/node_modules/better-sqlite3/build/Release/test_extension.node"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.business",
      "icon": "build/icon.icns",
      "identity": null
    },
    "dmg": {
      "title": "FoxBridge ${version}",
      "writeUpdateInfo": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    }
  }
}
